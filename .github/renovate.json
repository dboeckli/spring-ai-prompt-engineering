{
    "kubernetes": {"managerFilePatterns": [
        "/k8s/.+\\.ya?ml$/",
        "/helm-charts/templates/.+\\.ya?ml$/"
    ]},
    "helmv3": {"managerFilePatterns": ["/(^|/)Chart\\.ya?ml$/"]},
    "maven-wrapper": {
        "versioning": "maven",
        "managerFilePatterns": [
            "/(^|/)mvnw$/",
            "/(^|/)mvnw.cmd$/",
            "/(^|/).mvn/wrapper/maven-wrapper.properties$/"
        ]
    },
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "prConcurrentLimit": 0,
    "ignorePresets": ["workarounds:javaLTSVersions"],
    "dependencyDashboard": true,
    "rebaseWhen": "conflicted",
    "prHourlyLimit": 0,
    "separateMinorPatch": true,
    "automerge": false,
    "baseBranchPatterns": ["master"],
    "docker-compose": {"enabled": true},
    "helm-values": {"managerFilePatterns": ["/helm-charts/.+/values\\.ya?ml$/"]},
    "enabledManagers": [
        "maven",
        "maven-wrapper",
        "docker-compose",
        "kubernetes",
        "helm-values",
        "helmv3",
        "custom.regex"
    ],
    "separateMajorMinor": true,
    "extends": [
        "mergeConfidence:all-badges",
        "config:recommended"
    ],
    "customManagers": [
        {
            "customType": "regex",
            "datasourceTemplate": "custom.custom_java",
            "description": "Parse and change the java version from pom.xml",
            "autoReplaceStringTemplate": "<java.version>{{{newValue}}}<\/java.version>",
            "managerFilePatterns": ["/(^|\\/)pom\\.xml$/"],
            "depNameTemplate": "java",
            "matchStrings": ["<java\\.version>(?<currentValue>\\d+)<\/java\\.version>"]
        },
        {
            "customType": "regex",
            "datasourceTemplate": "custom.custom_java",
            "description": "Parse and change JAVA_VERSION in GitHub workflows",
            "autoReplaceStringTemplate": "  JAVA_VERSION: {{{newValue}}}",
            "managerFilePatterns": ["/^\\.github\\/workflows\\/(release|maven-build)\\.ya?ml$/"],
            "depNameTemplate": "java",
            "matchStrings": ["  JAVA_VERSION:[\\t ]*(?<currentValue>\\d+)"]
        }
    ],
    "packageRules": [
        {
            "matchPackageNames": ["org.springframework.boot:spring-boot-starter-parent"],
            "separateMultipleMajor": true,
            "description": "Track both Spring Boot 3.x and 4.x separately"
        },
        {
            "matchCategories": ["docker"],
            "registryUrls": ["https://index.docker.io"]
        },
        {
            "matchDatasources": ["docker"],
            "matchPackageNames": ["/^domboeckli//"],
            "versioning": "maven",
            "ignoreUnstable": false,
            "automerge": false,
            "automergeType": "pr",
            "ignoreTests": true,
            "allowedVersions": "/^[0-9]+\\.[0-9]+\\.[0-9]+(-SNAPSHOT)?$/"
        },
        {
            "matchDatasources": ["docker"],
            "matchPackageNames": ["!/^domboeckli//"],
            "automerge": false,
            "automergeType": "pr",
            "ignoreTests": true
        }
    ],
    "platformAutomerge": false,
    "branchPrefix": "feature/renovate-",
    "customDatasources": {"custom_java": {
        "defaultRegistryUrlTemplate": "https://api.adoptium.net/v3/info/available_releases",
        "format": "json",
        "transformTemplates": ["{ \"releases\": $map(available_lts_releases, function($v) { { \"version\": $string($v) } }) }"]
    }}
}
